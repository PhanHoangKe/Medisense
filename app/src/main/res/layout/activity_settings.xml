<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- App Bar with clean header -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/colorBackground"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_close"
            app:title="Cài đặt"
            app:titleTextAppearance="@style/TextAppearance.MediSense.TitleMedium"
            app:titleTextColor="?attr/colorOnSurface" />
            
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Profile / Guest User Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:cardBackgroundColor="?attr/colorSurfaceVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Circular Avatar Container -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="28dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="?attr/colorSecondaryContainer">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <ImageView
                                    android:id="@+id/imageAvatar"
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_person"
                                    app:tint="?attr/colorOnSecondaryContainer" />

                                <!-- Red notification badge dot -->
                                <View
                                    android:id="@+id/viewBadgeDot"
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:layout_gravity="top|end"
                                    android:layout_marginTop="2dp"
                                    android:layout_marginEnd="2dp"
                                    android:background="@android:color/holo_red_light" />
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:id="@+id/textUserTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Khách truy cập"
                                android:textAppearance="@style/TextAppearance.MediSense.TitleMedium"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/textUserSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hoàn thiện hồ sơ để lưu trữ và đồng bộ hóa dữ liệu trực tuyến."
                                android:textAppearance="@style/TextAppearance.MediSense.BodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Auth button text link -->
                    <TextView
                        android:id="@+id/buttonAuth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="16dp"
                        android:text="Hoàn thành hồ sơ"
                        android:textAppearance="@style/TextAppearance.MediSense.TitleSmall"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:padding="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pill-shaped button: Connect care recipient -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonFamilyConnect"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:text="Thêm người thân chăm sóc"
                android:textAppearance="@style/TextAppearance.MediSense.TitleSmall"
                android:textColor="?attr/colorOnPrimaryContainer"
                app:backgroundTint="?attr/colorPrimaryContainer"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_sync"
                app:iconGravity="textStart"
                app:iconTint="?attr/colorOnPrimaryContainer"
                app:strokeWidth="0dp" />

            <!-- GENERAL SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chung"
                android:textAppearance="@style/TextAppearance.MediSense.LabelMedium"
                android:textColor="?attr/colorOutline"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <!-- Item: Share QR -->
            <LinearLayout
                android:id="@+id/buttonShareQr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp"
                android:paddingHorizontal="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Chia sẻ mã QR kết nối"
                    android:textAppearance="@style/TextAppearance.MediSense.TitleMedium"
                    android:textColor="?attr/colorOnSurface" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="180"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutlineVariant" />

            <!-- Item: Export Report -->
            <LinearLayout
                android:id="@+id/buttonExportPdf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp"
                android:paddingHorizontal="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Xuất báo cáo PDF sức khỏe"
                    android:textAppearance="@style/TextAppearance.MediSense.TitleMedium"
                    android:textColor="?attr/colorOnSurface" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="180"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </LinearLayout>


            <!-- SECURITY & PRIVACY SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bảo mật &amp; Quyền riêng tư"
                android:textAppearance="@style/TextAppearance.MediSense.LabelMedium"
                android:textColor="?attr/colorOutline"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <!-- Collapsible Item: Biometric Security -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/rowBiometric"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="16dp"
                    android:paddingHorizontal="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Khóa vân tay &amp; Khuôn mặt"
                        android:textAppearance="@style/TextAppearance.MediSense.TitleMedium"
                        android:textColor="?attr/colorOnSurface" />

                    <ImageView
                        android:id="@+id/chevronBiometric"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_back"
                        android:rotation="-90"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <!-- Hidden Input Area -->
                <LinearLayout
                    android:id="@+id/layoutBiometricSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="16dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/textBiometricStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Khóa đang tắt"
                                android:textAppearance="@style/TextAppearance.MediSense.TitleSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bảo vệ lịch uống thuốc khỏi truy cập trái phép."
                                android:textAppearance="@style/TextAppearance.MediSense.BodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchBiometric"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Enroll Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonEnrollBiometric"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Đăng ký vân tay/khuôn mặt"
                        android:visibility="gone"
                        app:icon="@drawable/ic_lock" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutlineVariant"
                android:layout_marginBottom="24dp" />


            <!-- MEDICAL EMERGENCY SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Y tế khẩn cấp (SOS)"
                android:textAppearance="@style/TextAppearance.MediSense.LabelMedium"
                android:textColor="?attr/colorOutline"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <!-- Collapsible Item: Emergency SOS Settings -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/rowSos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="16dp"
                    android:paddingHorizontal="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Cài đặt thông tin SOS Medical ID"
                        android:textAppearance="@style/TextAppearance.MediSense.TitleMedium"
                        android:textColor="?attr/colorOnSurface" />

                    <ImageView
                        android:id="@+id/chevronSos"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_back"
                        android:rotation="-90"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <!-- Hidden Input Area for SOS -->
                <LinearLayout
                    android:id="@+id/layoutSosSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="16dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Hiển thị trên màn hình khóa"
                            android:textAppearance="@style/TextAppearance.MediSense.TitleSmall"
                            android:textColor="?attr/colorOnSurface" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchSos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Blood Type Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Nhóm máu"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editBloodType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:textAppearance="@style/TextAppearance.MediSense.BodyMedium" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Allergies Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Dị ứng"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editAllergies"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:lines="2"
                            android:textAppearance="@style/TextAppearance.MediSense.BodyMedium" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Medications Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Thuốc đang dùng"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editMedications"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:lines="2"
                            android:textAppearance="@style/TextAppearance.MediSense.BodyMedium" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ICE Contact Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="SĐT liên hệ khẩn cấp (ICE)"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editIceContact"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:textAppearance="@style/TextAppearance.MediSense.BodyMedium" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutlineVariant"
                android:layout_marginBottom="24dp" />


            <!-- PREFERENCES SECTION (MOCKUPS FOR AESTHETICS) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tùy chọn khác"
                android:textAppearance="@style/TextAppearance.MediSense.LabelMedium"
                android:textColor="?attr/colorOutline"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <!-- Item: Remove Ads -->
            <LinearLayout
                android:id="@+id/rowRemoveAds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp"
                android:paddingHorizontal="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Gỡ quảng cáo"
                    android:textAppearance="@style/TextAppearance.MediSense.TitleMedium"
                    android:textColor="?attr/colorOnSurface" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="180"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutlineVariant" />

            <!-- Item: Recommend App -->
            <LinearLayout
                android:id="@+id/rowRecommend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp"
                android:paddingHorizontal="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Giới thiệu MediSense"
                    android:textAppearance="@style/TextAppearance.MediSense.TitleMedium"
                    android:textColor="?attr/colorOnSurface" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="180"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutlineVariant" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
