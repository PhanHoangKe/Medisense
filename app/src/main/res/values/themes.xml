<resources xmlns:tools="http://schemas.android.com/tools">
    
    <!-- === MEDI SENSE 2026 - MATERIAL 3 DYNAMIC COLOR THEME === -->
    <!-- 
        This theme uses Material 3 Dynamic Colors (Monet) for Android 12+
        Falls back to static palette for older devices
    -->
    
    <!-- Base Theme with Dynamic Colors -->
    <style name="Base.Theme.MediSense" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Light Theme Colors -->
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>
        
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>
        
        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_light_onTertiaryContainer</item>
        
        <item name="colorError">@color/md_theme_light_error</item>
        <item name="colorOnError">@color/md_theme_light_onError</item>
        <item name="colorErrorContainer">@color/md_theme_light_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_light_onErrorContainer</item>
        
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="colorOnBackground">@color/md_theme_light_onBackground</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>
        <item name="colorOutline">@color/md_theme_light_outline</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/md_theme_light_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        
        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/md_theme_light_surface</item>
        <item name="android:windowLightNavigationBar">true</item>
        
        <!-- Shape Appearance - Rounded corners like MyTherapy -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.MediSense.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.MediSense.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.MediSense.LargeComponent</item>
        
        <!-- Typography -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.MediSense.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.MediSense.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.MediSense.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.MediSense.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.MediSense.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.MediSense.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.MediSense.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.MediSense.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.MediSense.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.MediSense.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.MediSense.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.MediSense.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.MediSense.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.MediSense.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.MediSense.LabelSmall</item>
    </style>

    <!-- Main Theme -->
    <style name="Theme.MediSense" parent="Base.Theme.MediSense">
        <!-- Override dynamic colors with app-specific seeds if needed -->
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorPrimaryDark">@color/md_theme_light_primary</item>
        <item name="colorAccent">@color/md_theme_light_primary</item>
    </style>
    
    <!-- Theme without dynamic colors (for pre-Android 12 or forced static) -->
    <style name="Theme.MediSense.Static" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>
        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_light_onTertiaryContainer</item>
        <item name="colorError">@color/md_theme_light_error</item>
        <item name="colorOnError">@color/md_theme_light_onError</item>
        <item name="colorErrorContainer">@color/md_theme_light_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_light_onErrorContainer</item>
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="colorOnBackground">@color/md_theme_light_onBackground</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>
        <item name="colorOutline">@color/md_theme_light_outline</item>
    </style>
    
    <!-- Splash Theme -->
    <style name="Theme.MediSense.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/md_theme_light_primary</item>
        <item name="android:statusBarColor">@color/md_theme_light_primary</item>
    </style>

    <!-- === TYPOGRAPHY - Inter font === -->
    <!-- Fallback: sans-serif khi GMS chưa tải font về -->

    <!-- Display -->
    <style name="TextAppearance.MediSense.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textSize">57sp</item>
        <item name="android:letterSpacing">-0.015625</item>
    </style>

    <style name="TextAppearance.MediSense.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textSize">45sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.MediSense.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textSize">36sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Headlines -->
    <style name="TextAppearance.MediSense.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textSize">32sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.MediSense.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textSize">28sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.MediSense.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Titles -->
    <style name="TextAppearance.MediSense.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textSize">22sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.MediSense.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textSize">16sp</item>
        <!-- 0.15sp / 16sp = 0.009375 em — đúng chuẩn Material 3 -->
        <item name="android:letterSpacing">0.009375</item>
    </style>

    <style name="TextAppearance.MediSense.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textSize">14sp</item>
        <!-- 0.1sp / 14sp = 0.00714 em -->
        <item name="android:letterSpacing">0.00714</item>
    </style>

    <!-- Body -->
    <style name="TextAppearance.MediSense.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/inter</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">16sp</item>
        <!-- 0.5sp / 16sp = 0.03125 em — đúng chuẩn Material 3 -->
        <item name="android:letterSpacing">0.03125</item>
        <item name="android:lineHeight">24sp</item>
    </style>

    <style name="TextAppearance.MediSense.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/inter</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">14sp</item>
        <!-- 0.25sp / 14sp = 0.01786 em -->
        <item name="android:letterSpacing">0.01786</item>
        <item name="android:lineHeight">20sp</item>
    </style>

    <style name="TextAppearance.MediSense.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/inter</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">12sp</item>
        <!-- 0.4sp / 12sp = 0.03333 em -->
        <item name="android:letterSpacing">0.03333</item>
        <item name="android:lineHeight">16sp</item>
    </style>

    <!-- Labels -->
    <style name="TextAppearance.MediSense.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textSize">14sp</item>
        <!-- 0.1sp / 14sp = 0.00714 em -->
        <item name="android:letterSpacing">0.00714</item>
    </style>

    <style name="TextAppearance.MediSense.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textSize">12sp</item>
        <!-- 0.5sp / 12sp = 0.04167 em -->
        <item name="android:letterSpacing">0.04167</item>
    </style>

    <style name="TextAppearance.MediSense.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textSize">11sp</item>
        <!-- 0.5sp / 11sp = 0.04545 em -->
        <item name="android:letterSpacing">0.04545</item>
    </style>

    <!-- === COMPONENT STYLES === -->
    <!-- Cards -->
    <style name="Widget.MediSense.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="contentPadding">@dimen/padding_card</item>
    </style>
    
    <style name="Widget.MediSense.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/elevation_none</item>
        <item name="strokeWidth">@dimen/stroke_thin</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="contentPadding">@dimen/padding_card</item>
    </style>
    
    <!-- FAB -->
    <style name="Widget.MediSense.FloatingActionButton" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="elevation">@dimen/elevation_large</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="tint">?attr/colorOnPrimary</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MediSense.Medium</item>
    </style>
    
    <style name="Widget.MediSense.FloatingActionButton.Secondary" parent="Widget.Material3.FloatingActionButton.Secondary">
        <item name="elevation">@dimen/elevation_medium</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MediSense.Medium</item>
    </style>
    
    <!-- Buttons -->
    <style name="Widget.MediSense.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">24dp</item>
        <item name="android:textAppearance">@style/TextAppearance.MediSense.LabelLarge</item>
        <item name="android:minHeight">@dimen/button_height_large</item>
        <item name="android:paddingStart">@dimen/padding_button_horizontal</item>
        <item name="android:paddingEnd">@dimen/padding_button_horizontal</item>
    </style>
    
    <style name="Widget.MediSense.Button.TextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAppearance">@style/TextAppearance.MediSense.LabelLarge</item>
    </style>
    
    <style name="Widget.MediSense.Button.OutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">24dp</item>
        <item name="strokeColor">?attr/colorPrimary</item>
        <item name="android:textAppearance">@style/TextAppearance.MediSense.LabelLarge</item>
        <item name="android:minHeight">@dimen/button_height_large</item>
    </style>
    
    <style name="Widget.MediSense.Button.ElevatedButton" parent="Widget.Material3.Button.ElevatedButton">
        <item name="cornerRadius">24dp</item>
        <item name="android:textAppearance">@style/TextAppearance.MediSense.LabelLarge</item>
    </style>
    
    <style name="Widget.MediSense.Button.TonalButton" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">24dp</item>
        <item name="android:textAppearance">@style/TextAppearance.MediSense.LabelLarge</item>
    </style>
    
    <!-- Text Fields -->
    <style name="Widget.MediSense.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_small</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_small</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_small</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_small</item>
    </style>
    
    <!-- Chips -->
    <style name="Widget.MediSense.Chip" parent="Widget.Material3.Chip.Assist">
        <item name="chipMinHeight">@dimen/chip_height</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MediSense.Chip</item>
    </style>
    
    <style name="Widget.MediSense.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipMinHeight">@dimen/chip_height</item>
    </style>
    
    <style name="Widget.MediSense.Chip.Action" parent="Widget.Material3.Chip.Assist">
        <item name="chipMinHeight">@dimen/chip_height</item>
    </style>
    
    <!-- Dialog -->
    <style name="Widget.MediSense.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearance">@style/ShapeAppearance.MediSense.Dialog</item>
    </style>
    
    <!-- Bottom Sheet -->
    <style name="Widget.MediSense.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearance">@style/ShapeAppearance.MediSense.BottomSheet</item>
    </style>
    
    <!-- Switch -->
    <style name="Widget.MediSense.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbTint">?attr/colorPrimary</item>
        <item name="trackTint">?attr/colorSurfaceVariant</item>
    </style>
    
    <!-- Slider -->
    <style name="Widget.MediSense.Slider" parent="Widget.Material3.Slider">
        <item name="trackHeight">@dimen/linear_progress_height_thick</item>
        <item name="thumbRadius">10dp</item>
    </style>
    
    <!-- Progress Indicators -->
    <style name="Widget.MediSense.CircularProgressIndicator" parent="Widget.Material3.CircularProgressIndicator">
        <item name="indicatorSize">@dimen/circular_progress_size_medium</item>
        <item name="trackThickness">@dimen/circular_progress_stroke_width</item>
    </style>
    
    <style name="Widget.MediSense.LinearProgressIndicator" parent="Widget.Material3.LinearProgressIndicator">
        <item name="trackThickness">@dimen/linear_progress_height</item>
    </style>
    
    <!-- Toolbar -->
    <style name="Widget.MediSense.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextAppearance">@style/TextAppearance.MediSense.TitleLarge</item>
        <item name="subtitleTextAppearance">@style/TextAppearance.MediSense.BodyMedium</item>
        <item name="android:minHeight">@dimen/app_bar_height</item>
    </style>
    
    <!-- Bottom Navigation -->
    <style name="Widget.MediSense.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="elevation">@dimen/elevation_none</item>
        <item name="itemIconSize">@dimen/icon_size_medium</item>
        <item name="itemPaddingTop">@dimen/spacing_8</item>
        <item name="itemPaddingBottom">@dimen/spacing_8</item>
    </style>
    
    <!-- Navigation Rail -->
    <style name="Widget.MediSense.NavigationRailView" parent="Widget.Material3.NavigationRailView">
        <item name="itemIconSize">@dimen/icon_size_medium</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.MediSense.NavigationRailView.ActiveIndicator</item>
    </style>
    
    <style name="Widget.MediSense.NavigationRailView.ActiveIndicator" parent="Widget.Material3.NavigationRailView.ActiveIndicator">
        <item name="android:width">56dp</item>
        <item name="android:height">32dp</item>
    </style>
    
    <!-- Tabs -->
    <style name="Widget.MediSense.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabTextAppearance">@style/TextAppearance.MediSense.LabelLarge</item>
    </style>
    
    <!-- List Items -->
    <style name="Widget.MediSense.ListItem" parent="">
        <item name="android:minHeight">@dimen/list_item_height_two_line</item>
        <item name="android:paddingStart">@dimen/padding_list_item</item>
        <item name="android:paddingEnd">@dimen/padding_list_item</item>
    </style>
    
    <!-- Divider -->
    <style name="Widget.MediSense.Divider" parent="">
        <item name="android:background">?attr/colorOutline</item>
        <item name="android:layout_height">@dimen/divider_height</item>
    </style>
    
    <!-- === PHASE 1.2 COMPONENT LIBRARY === -->
    
    <!-- Primary Button - Main CTA -->
    <style name="Widget.MediSense.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:minHeight">@dimen/button_height_large</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textAppearance">@style/TextAppearance.MediSense.LabelLarge</item>
        <item name="elevation">@dimen/elevation_small</item>
    </style>
    
    <!-- Secondary Button - Alternative action -->
    <style name="Widget.MediSense.Button.Secondary" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">?attr/colorSecondaryContainer</item>
        <item name="android:textColor">?attr/colorOnSecondaryContainer</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:minHeight">@dimen/button_height_large</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textAppearance">@style/TextAppearance.MediSense.LabelLarge</item>
    </style>
    
    <!-- Card Elevated - Floating cards with shadow -->
    <style name="Widget.MediSense.Card.Elevated" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/radius_large</item>
        <item name="cardElevation">@dimen/elevation_medium</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="contentPadding">@dimen/padding_card_large</item>
    </style>
    
    <!-- Card Filled - Solid color cards -->
    <style name="Widget.MediSense.Card.Filled" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/radius_large</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">?attr/colorSurfaceVariant</item>
        <item name="contentPadding">@dimen/padding_card_large</item>
    </style>
    
    <!-- Text Field - Outlined input -->
    <style name="Widget.MediSense.TextField" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_small</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_small</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_small</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_small</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextAppearance">@style/TextAppearance.MediSense.BodyMedium</item>
    </style>
    
    <style name="Widget.MediSense.TextField.Filled" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_small</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_small</item>
        <item name="boxBackgroundColor">?attr/colorSurfaceVariant</item>
    </style>
    
    <!-- Chip Choice - Single selection -->
    <style name="Widget.MediSense.Chip.Choice" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipMinHeight">32dp</item>
        <item name="chipStartPadding">12dp</item>
        <item name="chipEndPadding">12dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MediSense.Chip</item>
        <item name="android:textAppearance">@style/TextAppearance.MediSense.LabelMedium</item>
    </style>
    
    <!-- Chip Input - With delete icon -->
    <style name="Widget.MediSense.Chip.Input" parent="Widget.Material3.Chip.Input">
        <item name="chipMinHeight">32dp</item>
        <item name="chipIconEnabled">true</item>
        <item name="closeIconEnabled">true</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MediSense.Chip</item>
    </style>
    
    <!-- Chip Suggestion - For suggestions -->
    <style name="Widget.MediSense.Chip.Suggestion" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipMinHeight">32dp</item>
