<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    tools:context=".ui.AddMedicationActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- App Bar / Header -->
            <RelativeLayout
                android:id="@+id/layoutHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                app:layout_constraintTop_toTopOf="parent">

                <ImageButton
                    android:id="@+id/buttonBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="?attr/colorOnSurface"
                    android:contentDescription="Quay lại" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/buttonBack"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thêm thuốc mới"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Điền thông tin theo 3 bước đơn giản"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Steps Indicator -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutStepIndicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                app:layout_constraintTop_toBottomOf="@id/layoutHeader">

                <!-- Progress Line Background -->
                <View
                    android:id="@+id/stepProgressLine"
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:background="?attr/colorOutlineVariant"
                    app:layout_constraintStart_toStartOf="@id/step1Indicator"
                    app:layout_constraintEnd_toEndOf="@id/step3Indicator"
                    app:layout_constraintTop_toTopOf="@id/step1Indicator"
                    app:layout_constraintBottom_toBottomOf="@id/step1Indicator"
                    android:layout_marginTop="-12dp" />

                <!-- Step 1 -->
                <LinearLayout
                    android:id="@+id/step1Indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/step2Indicator"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintHorizontal_chainStyle="spread_inside">
                    <TextView
                        android:id="@+id/txtStep1Number"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/step_active_background"
                        android:text="1"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/txtStep1Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Tên &amp; Quét"
                        android:textSize="11sp"
                        android:textColor="@color/brand_primary"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Step 2 -->
                <LinearLayout
                    android:id="@+id/step2Indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    app:layout_constraintStart_toEndOf="@id/step1Indicator"
                    app:layout_constraintEnd_toStartOf="@id/step3Indicator"
                    app:layout_constraintTop_toTopOf="parent">
                    <TextView
                        android:id="@+id/txtStep2Number"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/step_inactive_background"
                        android:text="2"
                        android:gravity="center"
                        android:textColor="@color/gray_500"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/txtStep2Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Lịch &amp; Liều"
                        android:textSize="11sp"
                        android:textColor="@color/gray_500" />
                </LinearLayout>

                <!-- Step 3 -->
                <LinearLayout
                    android:id="@+id/step3Indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    app:layout_constraintStart_toEndOf="@id/step2Indicator"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <TextView
                        android:id="@+id/txtStep3Number"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/step_inactive_background"
                        android:text="3"
                        android:gravity="center"
                        android:textColor="@color/gray_500"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/txtStep3Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Kho &amp; Lưu"
                        android:textSize="11sp"
                        android:textColor="@color/gray_500" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ================= STEP 1 CONTAINER ================= -->
            <LinearLayout
                android:id="@+id/layoutStep1Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:visibility="visible"
                app:layout_constraintTop_toBottomOf="@id/layoutStepIndicator">

                <!-- Scan Box Button Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardScan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorPrimary"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="20dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="28dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="?attr/colorPrimaryContainer">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_camera"
                                app:tint="?attr/colorPrimary" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Quét đơn thuốc/vỏ hộp"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAlignment="center"
                            android:text="Tự động trích xuất thông tin thuốc từ nhãn hoặc đơn thuốc"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Form Title -->
                <TextView
                    android:id="@+id/textFormTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Hoặc nhập thủ công"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface" />

                <!-- OCR Banner -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/layoutOcrBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/textOcrBanner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/ocr_needs_review_banner"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/textOcrMissingFields"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textSize="12sp"
                            android:textColor="?attr/colorError"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/textOcrSource"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/ocr_source_label"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonViewOcrText"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/ocr_view_raw_text" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- OCR Info -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/layoutOcrInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/textOcrInfoTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Thông tin từ đơn thuốc"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary" />

                        <TextView
                            android:id="@+id/textOcrDiagnosis"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurface"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/textOcrDoctorAdvice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurface"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/textOcrInfoNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Nội dung này do AI trích xuất từ đơn thuốc, vui lòng kiểm tra lại với đơn thuốc gốc."
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Medication Name -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutMedicationName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    android:hint="@string/medication_name">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputMedicationName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Next button Step 1 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonStep1Next"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    app:cornerRadius="26dp"
                    android:text="Tiếp tục" />
            </LinearLayout>

            <!-- ================= STEP 2 CONTAINER ================= -->
            <LinearLayout
                android:id="@+id/layoutStep2Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/layoutStepIndicator">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bước 2: Lịch &amp; Liều lượng"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface" />

                <!-- Dosage Row -->
                <LinearLayout
                    android:id="@+id/layoutDosageRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <!-- Số lượng liều -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/inputLayoutDosageAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        android:hint="@string/dosage_amount_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputDosageAmount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:text="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Chọn nhanh đơn vị (Chips) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Chọn nhanh đơn vị:"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupDosageUnit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        app:singleSelection="true"
                        app:selectionRequired="false">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipUnitVien"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Viên"
                            app:chipStrokeColor="?attr/colorOutlineVariant"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipUnitMl"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ml"
                            app:chipStrokeColor="?attr/colorOutlineVariant"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipUnitGoi"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gói"
                            app:chipStrokeColor="?attr/colorOutlineVariant"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipUnitGiot"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Giọt"
                            app:chipStrokeColor="?attr/colorOutlineVariant"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipUnitKhac"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Khác..."
                            app:chipStrokeColor="?attr/colorOutlineVariant"
                            app:chipStrokeWidth="1dp" />
                    </com.google.android.material.chip.ChipGroup>

                    <!-- Đơn vị tùy chọn (Dropdown) - Ẩn mặc định, chỉ hiện khi chọn chip Khác -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/inputLayoutDosageUnit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        android:hint="@string/dosage_unit_hint">

                        <AutoCompleteTextView
                            android:id="@+id/dropdownDosageUnit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:text="Viên"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Instructions -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutInstructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    android:hint="@string/instructions">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputInstructions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="3" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Frequency -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutFrequency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    android:hint="@string/frequency_per_day">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputFrequency"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Khung giờ uống thuốc -->
                <TextView
                    android:id="@+id/textPickTimeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Khung giờ uống thuốc"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="?attr/colorOnSurface" />

                <LinearLayout
                    android:id="@+id/layoutTimePickers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

                <!-- Navigation buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    android:weightSum="2">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonStep2Back"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:textColor="?attr/colorPrimary"
                        android:text="Quay lại" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonStep2Next"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        app:cornerRadius="26dp"
                        android:text="Tiếp tục" />
                </LinearLayout>
            </LinearLayout>

            <!-- ================= STEP 3 CONTAINER ================= -->
            <LinearLayout
                android:id="@+id/layoutStep3Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/layoutStepIndicator">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bước 3: Kho thuốc &amp; Lưu trữ"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface" />

                <!-- Inventory Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardInventory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/inventory_section_title"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary" />

                        <!-- Tổng số thuốc -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/inputLayoutTotalStock"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            android:hint="@string/total_stock_hint_default">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/inputTotalStock"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Slider Liệu trình -->
                        <TextView
                            android:id="@+id/textDurationSliderLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Liệu trình dùng thuốc: 7 ngày"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderDuration"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:valueFrom="1"
                            android:valueTo="90"
                            android:stepSize="1"
                            android:value="7"
                            app:thumbColor="?attr/colorPrimary"
                            app:trackColorActive="?attr/colorPrimary"
                            app:trackColorInactive="?attr/colorOutlineVariant" />

                        <!-- Liệu trình nhanh -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/duration_label"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipGroupDuration"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            app:singleSelection="true"
                            app:selectionRequired="false">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip3days"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/duration_3_days"
                                app:chipStrokeColor="?attr/colorOutlineVariant"
                                app:chipStrokeWidth="1dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip5days"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/duration_5_days"
                                app:chipStrokeColor="?attr/colorOutlineVariant"
                                app:chipStrokeWidth="1dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip7days"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/duration_7_days"
                                app:chipStrokeColor="?attr/colorOutlineVariant"
                                app:chipStrokeWidth="1dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip14days"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/duration_14_days"
                                app:chipStrokeColor="?attr/colorOutlineVariant"
                                app:chipStrokeWidth="1dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip30days"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/duration_30_days"
                                app:chipStrokeColor="?attr/colorOutlineVariant"
                                app:chipStrokeWidth="1dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipContinuous"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/duration_continuous"
                                app:chipStrokeColor="?attr/colorOutlineVariant"
                                app:chipStrokeWidth="1dp" />
                        </com.google.android.material.chip.ChipGroup>

                        <!-- Smart Estimate -->
                        <TextView
                            android:id="@+id/textSmartEstimate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/smart_estimate_placeholder"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:padding="12dp"
                            android:background="@drawable/smart_estimate_background" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Switch Critical -->
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchCritical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Thuốc cấp cứu / Nhắc nhở nghiêm ngặt"
                    android:textColor="?attr/colorOnSurface"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                <!-- Navigation buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    android:weightSum="2">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonStep3Back"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:textColor="?attr/colorPrimary"
                        android:text="Quay lại" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonSaveMedication"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        app:cornerRadius="26dp"
                        android:text="@string/save_medication" />
                </LinearLayout>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
