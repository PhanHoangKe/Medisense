<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Capsule shadow -->
    <item android:left="4dp" android:top="8dp" android:right="4dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />
            <corners android:radius="28dp" />
            <size android:width="80dp" android:height="48dp" />
        </shape>
    </item>

    <!-- Capsule body - left half -->
    <item android:left="0dp" android:top="0dp" android:right="40dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#4CAF50" />
            <corners
                android:topLeftRadius="24dp"
                android:bottomLeftRadius="24dp" />
            <size android:width="40dp" android:height="48dp" />
        </shape>
    </item>

    <!-- Capsule body - right half -->
    <item android:left="40dp" android:top="0dp" android:right="0dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#81C784" />
            <corners
                android:topRightRadius="24dp"
                android:bottomRightRadius="24dp" />
            <size android:width="40dp" android:height="48dp" />
        </shape>
    </item>

    <!-- Highlight -->
    <item android:left="8dp" android:top="8dp" android:right="48dp" android:bottom="28dp">
        <shape android:shape="oval">
            <solid android:color="#60FFFFFF" />
        </shape>
    </item>

</layer-list>
