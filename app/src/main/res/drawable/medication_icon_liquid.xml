<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Bottle shadow -->
    <item android:left="4dp" android:top="8dp" android:right="4dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />
            <corners
                android:topLeftRadius="8dp"
                android:topRightRadius="8dp"
                android:bottomLeftRadius="16dp"
                android:bottomRightRadius="16dp" />
            <size android:width="40dp" android:height="56dp" />
        </shape>
    </item>

    <!-- Bottle body -->
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#90CAF9"
                android:endColor="#2196F3" />
            <corners
                android:topLeftRadius="8dp"
                android:topRightRadius="8dp"
                android:bottomLeftRadius="16dp"
                android:bottomRightRadius="16dp" />
            <size android:width="40dp" android:height="56dp" />
        </shape>
    </item>

    <!-- Label area -->
    <item android:left="4dp" android:top="20dp" android:right="4dp" android:bottom="20dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="2dp" />
            <size android:width="32dp" android:height="16dp" />
        </shape>
    </item>

    <!-- Liquid highlight -->
    <item android:left="8dp" android:top="4dp" android:right="24dp" android:bottom="40dp">
        <shape android:shape="rectangle">
            <solid android:color="#60FFFFFF" />
            <corners android:radius="2dp" />
            <size android:width="8dp" android:height="12dp" />
        </shape>
    </item>

</layer-list>
