<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_critical_alert_gradient"
    tools:context=".ui.CriticalAlertActivity">

    <!-- Card thông tin cảnh báo (Glassmorphic style) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardAlertInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#33FFFFFF"
        app:cardBackgroundColor="#1AFFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttonTaken"
        app:layout_constraintVertical_bias="0.4">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <ImageView
                android:id="@+id/iconWarning"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_warning_triangle"
                app:tint="#FF8A80" />

            <TextView
                android:id="@+id/textAlertTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="CẢNH BÁO UỐNG THUỐC"
                android:textColor="#FFCDD2"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/textMedicationName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                tools:text="Thuốc Huyết Áp" />

            <TextView
                android:id="@+id/textDosage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textColor="#E0E0E0"
                android:textSize="18sp"
                tools:text="1 viên" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Nút Đã Uống (Lớn, dễ bấm) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonTaken"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        android:text="Đã Uống"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/green_500"
        app:cornerRadius="32dp"
        app:layout_constraintBottom_toTopOf="@id/buttonSnooze"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Nút Nhắc Lại Sau -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonSnooze"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="40dp"
        android:text="Nhắc lại sau 10 phút"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        app:cornerRadius="28dp"
        app:strokeColor="#80FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

