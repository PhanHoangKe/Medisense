<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 
        Glassmorphism Chip Background
        Smaller glass effect for chips and pills
    -->
    
    <!-- Main body - highly transparent -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#C0FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    
    <!-- Top highlight -->
    <item android:left="1dp" android:top="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#60FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="15dp" />
        </shape>
    </item>
    
    <!-- Subtle border -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="0.5dp"
                android:color="#60FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    
</layer-list>
