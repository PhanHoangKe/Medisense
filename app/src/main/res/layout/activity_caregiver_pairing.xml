<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kết nối người thân"
        android:textAppearance="@style/TextAppearance.MediSense.HeadlineLarge"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- Connected State -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutConnected"
        style="?attr/materialCardViewFilledStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp"
        app:cardElevation="0dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvConnectedStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bạn đang kết nối với mã: ------"
                android:textAppearance="@style/TextAppearance.MediSense.TitleMedium"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDisconnect"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:text="Ngắt kết nối"
                app:cornerRadius="25dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Role Selection -->
    <LinearLayout
        android:id="@+id/layoutRoleSelection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bạn muốn kết nối theo vai trò nào?"
            android:textAppearance="@style/TextAppearance.MediSense.TitleMedium"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.card.MaterialCardView
            style="?attr/materialCardViewFilledStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tôi là Người bệnh"
                    android:textAppearance="@style/TextAppearance.MediSense.TitleMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tôi cần người thân theo dõi lịch uống thuốc của mình."
                    android:textAppearance="@style/TextAppearance.MediSense.BodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectPatient"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="16dp"
                    android:text="Chọn vai trò này"
                    app:cornerRadius="25dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="?attr/materialCardViewFilledStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tôi là Người giám sát"
                    android:textAppearance="@style/TextAppearance.MediSense.TitleMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tôi muốn theo dõi lịch uống thuốc của người thân."
                    android:textAppearance="@style/TextAppearance.MediSense.BodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectCaregiver"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="16dp"
                    android:text="Chọn vai trò này"
                    app:cornerRadius="25dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Patient Flow -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutPatientFlow"
        style="?attr/materialCardViewFilledStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp"
        app:cardElevation="0dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dành cho Người bệnh"
                android:textAppearance="@style/TextAppearance.MediSense.TitleMedium"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tạo mã để người thân có thể theo dõi lịch uống thuốc của bạn."
                android:textAppearance="@style/TextAppearance.MediSense.BodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateCode"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:text="Tạo mã kết nối"
                android:textColor="?attr/colorOnPrimary"
                app:backgroundTint="?attr/colorPrimary"
                app:cornerRadius="25dp" />

            <TextView
                android:id="@+id/tvGeneratedCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.MediSense.HeadlineLarge"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:textColor="?attr/colorPrimary"
                android:text="------"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.2" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackToRoleFromPatient"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="Quay lại chọn vai trò"
                android:textColor="?attr/colorPrimary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Caregiver Flow -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutCaregiverFlow"
        style="?attr/materialCardViewFilledStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp"
        app:cardElevation="0dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dành cho Người giám sát"
                android:textAppearance="@style/TextAppearance.MediSense.TitleMedium"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nhập mã từ người bệnh để bắt đầu theo dõi."
                android:textAppearance="@style/TextAppearance.MediSense.BodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutInputCaregiverCode"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Mã kết nối (6 ký tự)"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_camera"
                app:endIconContentDescription="Quét mã QR"
                app:endIconTint="?attr/colorPrimary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputCaregiverCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLength="6"
                    android:textAppearance="@style/TextAppearance.MediSense.BodyMedium"
                    android:textColor="?attr/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConnectCaregiver"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:text="Kết nối"
                android:textColor="?attr/colorOnPrimary"
                app:backgroundTint="?attr/colorPrimary"
                app:cornerRadius="25dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackToRoleFromCaregiver"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="Quay lại chọn vai trò"
                android:textColor="?attr/colorPrimary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
