<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Tablet shadow -->
    <item android:left="4dp" android:top="8dp" android:right="4dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />
            <corners android:radius="8dp" />
            <size android:width="48dp" android:height="48dp" />
        </shape>
    </item>

    <!-- Tablet body with gradient -->
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FFCC80"
                android:endColor="#FF9800" />
            <corners android:radius="8dp" />
            <size android:width="48dp" android:height="48dp" />
        </shape>
    </item>

    <!-- Score line in middle -->
    <item android:left="23dp" android:top="8dp" android:right="23dp" android:bottom="12dp">
        <shape android:shape="rectangle">
            <solid android:color="#CCFFFFFF" />
            <corners android:radius="1dp" />
            <size android:width="2dp" android:height="32dp" />
        </shape>
    </item>

    <!-- Highlight -->
    <item android:left="8dp" android:top="8dp" android:right="28dp" android:bottom="28dp">
        <shape android:shape="oval">
            <solid android:color="#50FFFFFF" />
        </shape>
    </item>

</layer-list>
